# ── 厂区访客设备本地管控 — 环境变量示例 ──
# 复制为 .env 后按需修改：cp .env.example .env

# 服务
PORT=3000
NODE_ENV=development

# 安全（生产环境必须修改）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# 本地管理员（首次 db:migrate 时自动创建）
SUPER_ADMIN_EMAIL=admin@factory.local
SUPER_ADMIN_PASSWORD=change-me-in-production
SUPER_ADMIN_NAME=厂区管理员

# 数据库
DB_PATH=./data/factory.db
DB_AUTO_MIGRATE=true

# 局域网部署：无需公网 URL；留空则使用本机 IP
PUBLIC_URL=

# TLS（可选，局域网 HTTP 通常足够）
TLS_ENABLED=false

# SMTP（可选，用于忘记密码邮件）
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Sentry（可选）
SENTRY_DSN=
