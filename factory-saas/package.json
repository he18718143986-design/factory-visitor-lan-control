{
  "name": "factory-control-server",
  "version": "2.0.0",
  "description": "厂区访客设备本地管控 — 门卫电脑端控制台",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern=__tests__/unit --forceExit",
    "test:integration": "jest --testPathPattern=__tests__/integration --forceExit --detectOpenHandles",
    "db:migrate": "node db/migrate-cli.js",
    "db:backup": "node scripts/backup-db.js",
    "verify:state-machine": "node scripts/verify-subscription-state-machine.js",
    "verify:p1-2-gate": "node scripts/verify-p1-2-manual-gate.js",
    "verify:security": "node scripts/verify-security-defaults.js"
  },
  "dependencies": {
    "@sentry/node": "^10.47.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.0",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
